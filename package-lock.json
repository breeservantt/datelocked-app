import { createClient } from 'npm:@supabase/supabase-js@2'

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, content-type, apikey, x-client-info',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
  'Content-Type': 'application/json',
}

Deno.serve(async (req) => {
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    if (req.method !== 'POST') {
      return jsonResponse({ error: 'Method not allowed' }, 405)
    }

    const supabaseUrl = Deno.env.get('SUPABASE_URL')
    const supabaseAnonKey = Deno.env.get('SUPABASE_ANON_KEY')
    const supabaseServiceRoleKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')

    if (!supabaseUrl || !supabaseAnonKey || !supabaseServiceRoleKey) {
      return jsonResponse(
        {
          error:
            'Missing required environment variables: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY',
        },
        500
      )
    }

    const authHeader = req.headers.get('Authorization')
    if (!authHeader?.startsWith('Bearer ')) {
      return jsonResponse({ error: 'Unauthorized' }, 401)
    }

    const userClient = createClient(supabaseUrl, supabaseAnonKey, {
      global: {
        headers: {
          Authorization: authHeader,
        },
      },
    })

    const adminClient = createClient(supabaseUrl, supabaseServiceRoleKey)

    const {
      data: { user: authUser },
      error: authError,
    } = await userClient.auth.getUser()

    if (authError || !authUser) {
      return jsonResponse({ error: 'Unauthorized' }, 401)
    }

    const body = await req.json().catch(() => null)
    const code = body?.code?.toString().trim()

    if (!code) {
      return jsonResponse({ error: 'Code is required' }, 400)
    }

    const { data: currentUser, error: currentUserError } = await adminClient
      .from('User')
      .select('*')
      .eq('id', authUser.id)
      .single()

    if (currentUserError || !currentUser) {
      return jsonResponse({ error: 'User profile not found' }, 404)
    }

    const { data: codes, error: codeError } = await adminClient
      .from('DateLockCode')
      .select('*')
      .eq('code', code)
      .eq('status', 'active')

    if (codeError) {
      return jsonResponse({ error: codeError.message }, 500)
    }

    if (!codes || codes.length === 0) {
      return jsonResponse({ error: 'Invalid or expired code' }, 404)
    }

    const dateLockCode = codes[0]

    const expiresAt = new Date(dateLockCode.expires_at)
    if (Number.isNaN(expiresAt.getTime())) {
      return jsonResponse({ error: 'Invalid expiry date on code' }, 500)
    }

    if (expiresAt.getTime() < Date.now()) {
      await adminClient
        .from('DateLockCode')
        .update({ status: 'expired' })
        .eq('id', dateLockCode.id)

      return jsonResponse({ error: 'Code has expired' }, 400)
    }

    if (dateLockCode.creator_email === authUser.email) {
      return jsonResponse({ error: 'You cannot redeem your own code' }, 400)
    }

    if (
      currentUser.relationship_status === 'date_locked' &&
      currentUser.couple_profile_id
    ) {
      return jsonResponse(
        { error: 'You are already Date-Locked with someone' },
        400
      )
    }

    const { data: creatorUsers, error: creatorUsersError } = await adminClient
      .from('User')
      .select('*')
      .eq('email', dateLockCode.creator_email)

    if (creatorUsersError) {
      return jsonResponse({ error: creatorUsersError.message }, 500)
    }

    if (!creatorUsers || creatorUsers.length === 0) {
      return jsonResponse({ error: 'Code creator not found' }, 404)
    }

    const creatorUser = creatorUsers[0]

    if (
      creatorUser.relationship_status === 'date_locked' &&
      creatorUser.couple_profile_id
    ) {
      return jsonResponse(
        { error: 'Code creator is already Date-Locked with someone' },
        400
      )
    }

    const { data: existingCouple, error: existingCoupleError } = await adminClient
      .from('CoupleProfile')
      .select('id')
      .or(
        `and(partner1_email.eq.${dateLockCode.creator_email},partner2_email.eq.${authUser.email}),and(partner1_email.eq.${authUser.email},partner2_email.eq.${dateLockCode.creator_email})`
      )
      .maybeSingle()

    if (existingCoupleError) {
      return jsonResponse({ error: existingCoupleError.message }, 500)
    }

    if (existingCouple) {
      return jsonResponse(
        { error: 'You are already linked in an existing couple profile' },
        400
      )
    }

    const nowIso = new Date().toISOString()

    const { data: coupleProfile, error: coupleProfileError } = await adminClient
      .from('CoupleProfile')
      .insert({
        partner1_email: dateLockCode.creator_email,
        partner2_email: authUser.email,
        date_locked_at: nowIso,
      })
      .select()
      .single()

    if (coupleProfileError || !coupleProfile) {
      return jsonResponse(
        { error: coupleProfileError?.message || 'Failed to create couple profile' },
        500
      )
    }

    const { error: codeUpdateError } = await adminClient
      .from('DateLockCode')
      .update({
        status: 'redeemed',
        redeemed_by: authUser.email,
        redeemed_at: nowIso,
      })
      .eq('id', dateLockCode.id)

    if (codeUpdateError) {
      await adminClient.from('CoupleProfile').delete().eq('id', coupleProfile.id)
      return jsonResponse(
        { error: codeUpdateError.message || 'Failed to update code status' },
        500
      )
    }

    const { error: creatorUpdateError } = await adminClient
      .from('User')
      .update({
        relationship_status: 'date_locked',
        partner_email: authUser.email,
        couple_profile_id: coupleProfile.id,
      })
      .eq('id', creatorUser.id)

    if (creatorUpdateError) {
      await rollback(adminClient, coupleProfile.id, dateLockCode.id)
      return jsonResponse(
        { error: creatorUpdateError.message || 'Failed to update creator profile' },
        500
      )
    }

    const { error: currentUserUpdateError } = await adminClient
      .from('User')
      .update({
        relationship_status: 'date_locked',
        partner_email: dateLockCode.creator_email,
        couple_profile_id: coupleProfile.id,
      })
      .eq('id', currentUser.id)

    if (currentUserUpdateError) {
      await rollback(adminClient, coupleProfile.id, dateLockCode.id)
      return jsonResponse(
        { error: currentUserUpdateError.message || 'Failed to update current user profile' },
        500
      )
    }

    return jsonResponse({
      success: true,
      couple_profile_id: coupleProfile.id,
      partner_name: dateLockCode.creator_name,
      message: `You are now Date-Locked with ${dateLockCode.creator_name}!`,
    })
  } catch (error) {
    console.error('Redeem Date-Lock code error:', error)

    return jsonResponse(
      { error: error instanceof Error ? error.message : 'Unknown server error' },
      500
    )
  }
})

async function rollback(
  adminClient: ReturnType<typeof createClient>,
  coupleProfileId: string,
  codeId: string
) {
  await adminClient.from('CoupleProfile').delete().eq('id', coupleProfileId)
  await adminClient
    .from('DateLockCode')
    .update({
      status: 'active',
      redeemed_by: null,
      redeemed_at: null,
    })
    .eq('id', codeId)
}

function jsonResponse(data: unknown, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: corsHeaders,
  })
}
